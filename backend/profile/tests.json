{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Create new user",
      "method": "POST",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Send without email returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "send"},
      "expectedStatus": 400
    },
    {
      "name": "Verify without code returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "verify", "email": "test@example.com"},
      "expectedStatus": 400
    }
  ]
}